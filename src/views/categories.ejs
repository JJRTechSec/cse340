<%- include('partials/header') %>
  <main class="categories">
    <h1>
      <%= title %>
    </h1>
    <ul>
      <% categories.forEach(category => { %>
        <li>
          <h2><%= category.name %></h2>
          <p><%= category.description %></p>
        </li>
      <% }) %>
    </ul>
    
  </main>

  <%- include('partials/footer') %>